{
  "productName": "Vivant",
  "version": "0.1.0",
  "identifier": "dev.vivant.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": ["icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "linux": {
      "deb": {
        "depends": ["libwebkitgtk-6.0-0"],
        "files": {
          "/usr/share/applications/Vivant.desktop": "assets/vivant.desktop"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/applications/Vivant.desktop": "assets/vivant.desktop"
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Vivant",
        "width": 1200,
        "height": 780,
        "minWidth": 720,
        "minHeight": 500,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  }
}
